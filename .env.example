# PostgreSQL Configuration
PGHOST=
PGUSER=
PGDATABASE=
PGPASSWORD=
PGPORT=5432

# Authentication
JWT_SECRET=

# Paystack
VITE_PAYSTACK_PUBLIC_KEY=
VITE_PAYFAST_MERCHANT_ID=
VITE_PAYFAST_MERCHANT_KEY=
VITE_PAYFAST_URL=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# GAAP POS Integration
WAYTA_TO_GAAP_SECRET=

# Stitch Payments
STITCH_CLIENT_ID=
STITCH_CLIENT_SECRET=
STITCH_API_URL=https://api.stitch.money/graphql
STITCH_AUTH_URL=https://sts.stitch.money/connect/token
STITCH_REDIRECT_URL=https://payment.auth.wayta.co.za/payment-authorization.html
STITCH_FAILURE_URL=https://payment.failed.wayta.co.za/
STITCH_WEBHOOK_URL=https://payment.notifications.wayta.co.za/

# Mailtrap
MAILTRAP_HOST=live.smtp.mailtrap.io
MAILTRAP_PORT=587
MAILTRAP_USER=api
MAILTRAP_PASS=

# Gemini API
GEMINI_API_KEY=

# PayPal Business Integration
VITE_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox # sandbox or live

# --- Admin / developer access (unset = that login path is disabled) ---
# Client (baked in at build time — do NOT set these for public builds like GitHub Pages)
VITE_ADMIN_WHITELISTED_EMAIL=
VITE_SUPER_ADMIN_EMAIL=
VITE_ADMIN_USERNAME=
VITE_ADMIN_PASSWORD=
VITE_SUPER_ADMIN_PASSWORD=
VITE_SUPER_ADMIN_PIN=

# Server (dist/server.cjs)
WAYTA_ADMIN_PIN=
WAYTA_SUPER_ADMIN_EMAIL=
# Comma-separated list of accepted super-admin pins
WAYTA_SUPER_ADMIN_PINS=

# --- Deploy base path (defaults to /wayta-ai-studio/ for GitHub Pages; use / for Cloud Run) ---
# VITE_BASE_PATH=/
